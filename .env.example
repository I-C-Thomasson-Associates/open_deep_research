OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
LANGSMITH_TRACING=false
LANGCHAIN_TRACING_V2=false
LANGCHAIN_CALLBACKS_ENABLED=false

# Only necessary for Open Agent Platform
SUPABASE_KEY=
SUPABASE_URL=
# Should be set to true for a production deployment on Open Agent Platform. Should be set to false otherwise, such as for local development.
GET_API_KEYS_FROM_CONFIG=false

# ---- Azure Key Vault runtime fallback (optional) ----
# When VAULT_HOST is set, src/open_deep_research/env.py's get_secret() will
# fetch any missing secret from Azure Key Vault before falling back to the
# env var above. Key lookup converts underscores to hyphens
# (e.g. TAVILY_API_KEY -> TAVILY-API-KEY).
#
# AZURE_CLIENT_ID is picked up automatically by DefaultAzureCredential to
# select the managed identity (typically the AKS kubelet identity) that
# has Get/List permissions on the Key Vault.
VAULT_HOST=
AZURE_CLIENT_ID=